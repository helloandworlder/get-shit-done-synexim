{
  "name": "get-shit-done-synexim",
  "version": "1.22.4",
  "description": "A Chinese-first, adaptive GSD fork for Claude Code, OpenCode, Gemini and Codex by Synexim.",
  "bin": {
    "get-shit-done-synexim": "bin/install.js"
  },
  "files": [
    "bin",
    "commands",
    "get-shit-done",
    "agents",
    "hooks/dist",
    "scripts"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "meta-prompting",
    "context-engineering",
    "spec-driven-development",
    "gemini",
    "gemini-cli",
    "codex",
    "codex-cli"
  ],
  "author": "Synexim",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helloandworlder/get-shit-done-synexim.git"
  },
  "homepage": "https://github.com/helloandworlder/get-shit-done-synexim",
  "bugs": {
    "url": "https://github.com/helloandworlder/get-shit-done-synexim/issues"
  },
  "engines": {
    "node": ">=16.7.0"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "esbuild": "^0.24.0"
  },
  "scripts": {
    "build:hooks": "node scripts/build-hooks.js",
    "prepublishOnly": "npm run build:hooks",
    "test": "node scripts/run-tests.cjs",
    "test:coverage": "c8 --check-coverage --lines 70 --reporter text --include 'get-shit-done/bin/lib/*.cjs' --exclude 'tests/**' --all node scripts/run-tests.cjs"
